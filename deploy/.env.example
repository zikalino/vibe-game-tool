# Example environment file for the vibe-game-tool backend stack.
# Copy this file to .env and fill in all values before running deploy.sh.

# Your registered GitHub OAuth App credentials
GH_CLIENT_ID=your_github_client_id_here
GH_CLIENT_SECRET=your_github_client_secret_here

# A long, random secret used to sign JWTs.
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace_with_a_random_32_byte_hex_string

# SQLite path inside the container (default is fine; change only if switching to PostgreSQL).
# For SQLite:  sqlite:///app/data/app.db
# For PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///app/data/app.db

# Public hostname for your service (used by Caddy for automatic HTTPS).
# Must be a fully-qualified domain name for Caddy to obtain a TLS certificate
# automatically (e.g. DOMAIN=game.example.com).
# If you only have an IP address and no domain yet, set DOMAIN to the IP;
# the game will be served over plain HTTP on port 80.
# Example (domain): DOMAIN=game.example.com
# Example (IP only): DOMAIN=203.0.113.10
DOMAIN=your.domain.here
